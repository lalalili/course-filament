{
    "name": "lalalili/course-filament",
    "description": "Filament admin UI integration for lalalili/course-core.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "lalalili/course-core": "^0.1|^0.2",
        "filament/filament": "^4.0|^5.0",
        "filament/actions": "^4.0|^5.0",
        "filament/forms": "^4.0|^5.0",
        "filament/schemas": "^4.0|^5.0",
        "filament/tables": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "autoload": {
        "psr-4": {
            "Lalalili\\CourseFilament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lalalili\\CourseFilament\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/lalalili/course-core.git"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Lalalili\\CourseFilament\\CourseFilamentServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.0"
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
